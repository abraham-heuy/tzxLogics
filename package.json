{
    "name": "tzx-backend",
    "version": "1.0.0",
    "description": "Backend for TZX Trading platform",
    "main": "dist/server.js",
    "type": "commonjs",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "nodemon src/index.ts",
        "build": "tsc",
        "typeorm": "typeorm-ts-node-commonjs",
        "migration:generate": "npm run typeorm -- migration:generate -d ./src/config/data-source.ts",
        "migration:run": "npm run typeorm -- migration:run -d ./src/config/data-source.ts",
        "migration:revert": "npm run typeorm -- migration:revert -d ./src/config/data-source.ts"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-validator": "^7.2.0",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^6.9.16",
        "pg": "^8.19.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.19.13",
        "@types/nodemailer": "^6.4.17",
        "@types/pg": "^8.11.11",
        "nodemon": "^3.1.10",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.8.2"
    }
}
